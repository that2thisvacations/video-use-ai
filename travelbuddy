#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BIN="$SCRIPT_DIR/.venv/bin/python3.11"
DEMO_SCRIPT="$SCRIPT_DIR/travelbuddy_demo.py"

usage() {
  cat <<'EOF'
Usage:
  ./travelbuddy reel "Travel is the new freedom." [extra args...]
  ./travelbuddy batch examples/topics_daily.txt [extra args...]

Examples:
  ./travelbuddy reel "Travel is the new freedom."
  ./travelbuddy reel "Travel is the new freedom." --pause-profile dramatic
  ./travelbuddy reel "AI is replacing average marketing." --mode ai_marketing
  ./travelbuddy reel "AI is replacing average marketing." --seedance-payload-only
  ./travelbuddy batch examples/topics_daily.txt
  ./travelbuddy batch examples/topics_daily.txt --pause-profile dramatic
  ./travelbuddy batch examples/topics_daily.txt --mode motivational

The wrapper adds:
  --travelbuddy-reel
  --open-output

Extra args are forwarded to travelbuddy_demo.py so manual overrides still win.
EOF
}

banner() {
  cat <<'EOF'
==================================================
TRAVELBUDDY CREATOR MODE
==================================================
EOF
}

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

mode="$1"
shift

if [[ ! -x "$PYTHON_BIN" ]]; then
  echo "Missing Python runtime: $PYTHON_BIN" >&2
  exit 1
fi

if [[ ! -f "$DEMO_SCRIPT" ]]; then
  echo "Missing demo script: $DEMO_SCRIPT" >&2
  exit 1
fi

case "$mode" in
  reel)
    if [[ $# -lt 1 ]]; then
      echo "Missing topic for reel mode." >&2
      usage >&2
      exit 1
    fi
    topic="$1"
    shift
    banner
    exec "$PYTHON_BIN" "$DEMO_SCRIPT" --travelbuddy-reel --open-output --topic "$topic" "$@"
    ;;
  batch)
    if [[ $# -lt 1 ]]; then
      echo "Missing topics file for batch mode." >&2
      usage >&2
      exit 1
    fi
    topics_file="$1"
    shift
    banner
    exec "$PYTHON_BIN" "$DEMO_SCRIPT" --travelbuddy-reel --open-output --topics-file "$topics_file" "$@"
    ;;
  *)
    echo "Unknown command: $mode" >&2
    usage >&2
    exit 1
    ;;
esac
